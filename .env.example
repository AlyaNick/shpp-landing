# Email оператора — приём заявок (отправка через Яндекс SMTP)
OPERATOR_EMAIL=your-email@yandex.ru
# Пароль приложения Яндекс (Безопасность → Пароли приложений)
YANDEX_APP_PASSWORD=your-yandex-app-password
# Локально: .env в корне проекта. После npm run build — скопируйте в dist/
# npm run dev  — Vite + Node API (Яндекс SMTP, PHP не нужен)
# npm run start — раздача dist/ + API (Node, после сборки)
# PORT=3001
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
